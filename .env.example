DATABASE_URL=your_database_url

# ── Email: SMTP (via nodemailer) ──────────────────────────────────────────────
# Point these at any SMTP provider (your mail server, a transactional provider's
# SMTP, etc.). Leave SMTP_HOST unset to disable sending (sign-ups still work).
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# The "from" address. To land in the INBOX (not spam) this MUST be on a domain
# whose SPF + DKIM + DMARC are set up for the SMTP provider above.
EMAIL_FROM=Wuh Water Doing <alerts@your-verified-domain>

# Public URL of the app — used to build unsubscribe links in alert emails.
APP_URL=http://localhost:3000

# Secret that protects the cron endpoint. Set the same value as a GitHub Actions
# secret (the scheduled workflow sends it). If unset, the endpoint is open (dev).
CRON_SECRET=your_cron_secret

# Optional: where "something broke" ops alerts go (used by the checker).
ADMIN_EMAIL=you@example.com
