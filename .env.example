DATABASE_URL=your_database_url

# ── Email: Resend ─────────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# The "from" address. To land in the INBOX (not spam) this MUST be an address on
# a domain you've VERIFIED in Resend (SPF + DKIM + DMARC). The shared test
# sender below only reaches your own Resend account address and tends to spam.
EMAIL_FROM=Wuh Water Doing <alerts@your-verified-domain>
# EMAIL_FROM=Wuh Water Doing <onboarding@resend.dev>   # test only

# Public URL of the app — used to build unsubscribe links in alert emails.
APP_URL=http://localhost:3000

# Secret that protects the cron endpoint. Set the same value in Vercel and the
# scheduler sends it automatically. If unset, the endpoint is open (dev only).
CRON_SECRET=your_cron_secret

# Optional: where "something broke" ops alerts go (used by the checker).
ADMIN_EMAIL=you@example.com
